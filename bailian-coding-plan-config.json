{
  "comment": "百炼 Coding Plan 成本管控配置 - 应用到 Gateway 后删除此文件",
  
  "models": {
    "providers": {
      "dashscope-coding": {
        "baseUrl": "https://coding.dashscope.aliyuncs.com/v1",
        "models": [
          {
            "id": "qwen3.5-plus",
            "cost": {
              "input": 0.0028,
              "output": 0.0084,
              "cacheRead": 0.0014,
              "cacheWrite": 0
            }
          },
          {
            "id": "qwen3-max-2025-09-23",
            "cost": {
              "input": 0.014,
              "output": 0.042,
              "cacheRead": 0.007,
              "cacheWrite": 0
            }
          }
        ]
      }
    }
  },

  "agents": {
    "defaults": {
      "subagents": {
        "model": "dashscope-coding/qwen3.5-plus",
        "thinking": "off",
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 5,
        "maxConcurrent": 8,
        "runTimeoutSeconds": 900,
        "archiveAfterMinutes": 60
      }
    }
  },

  "commands": {
    "usage": true
  },

  "logging": {
    "model": {
      "usage": true
    }
  }
}

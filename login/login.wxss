.container {
    padding: 40rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  }
  
  .card {
    width: 680rpx;
    background: #fff;
    border-radius: 24rpx;
    box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.1);
    padding: 60rpx 40rpx;
    align-items: center;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  
  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 8rpx;
    background: linear-gradient(90deg, #667eea, #764ba2);
  }
  
  .title {
    font-size: 40rpx;
    color: #333;
    margin-bottom: 40rpx;
    font-weight: bold;
    position: relative;
  }
  
  .title::after {
    content: '';
    position: absolute;
    bottom: -10rpx;
    left: 50%;
    transform: translateX(-50%);
    width: 60rpx;
    height: 4rpx;
    background: linear-gradient(90deg, #667eea, #764ba2);
    border-radius: 2rpx;
  }
  
  .role-section {
    width: 100%;
    margin-bottom: 40rpx;
  }
  
  .section-title {
    font-size: 28rpx;
    color: #555;
    margin-bottom: 30rpx;
    font-weight: 600;
  }
  
  .role-group {
    width: 100%;
  }
  
  .role-item {
    display: flex;
    align-items: flex-start;
    margin-bottom: 24rpx;
    padding: 20rpx;
    border-radius: 16rpx;
    background: #f8f9fa;
    transition: all 0.3s ease;
  }
  
  .role-item:hover {
    background: #e9ecef;
    transform: translateY(-2rpx);
  }
  
  .role-item:last-child {
    margin-bottom: 0;
  }
  
  .role-item radio {
    margin-right: 20rpx;
    margin-top: 6rpx;
  }
  
  .role-info {
    flex: 1;
    text-align: left;
  }
  
  .role-label {
    font-size: 28rpx;
    color: #333;
    font-weight: 600;
    margin-bottom: 8rpx;
  }
  
  .role-desc {
    font-size: 24rpx;
    color: #666;
    line-height: 1.4;
  }
  
  .profile {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 30rpx;
  }
  
  .avatar {
    width: 140rpx;
    height: 140rpx;
    border-radius: 70rpx;
    margin-bottom: 20rpx;
    border: 4rpx solid #f0f0f0;
  }
  
  .nick {
    font-size: 32rpx;
    color: #333;
    font-weight: 600;
  }
  
  .actions {
    margin-top: 30rpx;
    width: 100%;
  }
  
  .login-btn {
    width: 100%;
    background: linear-gradient(90deg, #667eea, #764ba2);
    color: #fff;
    padding: 24rpx 0;
    border-radius: 50rpx;
    font-size: 32rpx;
    font-weight: 600;
    box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
    transition: all 0.3s ease;
  }
  
  .login-btn:active {
    transform: translateY(2rpx);
    box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  }
  
  .logout-btn {
    width: 100%;
    background: #f2f2f2;
    color: #666;
    padding: 20rpx 0;
    border-radius: 50rpx;
    font-size: 28rpx;
    font-weight: 500;
    transition: all 0.3s ease;
  }
  
  .logout-btn:active {
    background: #e9ecef;
  }
  
  .status {
    margin-top: 30rpx;
    color: #666;
    font-size: 26rpx;
    padding: 16rpx 24rpx;
    background: #f8f9fa;
    border-radius: 12rpx;
    border-left: 4rpx solid #667eea;
  }
  
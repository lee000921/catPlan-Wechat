[general]
# 数据源: tushare, akshare, mock
data_source = tushare

[tushare]
# Tushare API Token (从 https://tushare.pro/user/token 获取)
token = YOUR_TUSHARE_TOKEN

[cache]
# 是否启用缓存
enabled = true
# 缓存过期时间(秒)
ttl = 3600

[request]
# 请求超时时间(秒)
timeout = 30
# 最大重试次数
max_retries = 3

[logging]
# 日志级别: DEBUG, INFO, WARNING, ERROR
level = INFO
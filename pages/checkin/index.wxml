<view class="checkin-container">
  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." inherit-color />
  </view>

  <block wx:else>
    <!-- 未登录状态 -->
    <view class="not-login" wx:if="{{!isLogin}}">
      <view class="login-tips">登录后开始签到获取碎片</view>
      <t-button theme="primary" size="large" bind:tap="goToLogin">去登录</t-button>
    </view>

    <!-- 已登录状态 -->
    <block wx:else>
      <!-- 顶部签到信息 -->
      <view class="checkin-header">
        <view class="user-info">
          <image class="avatar" src="{{userInfo.avatarUrl || '/assets/icons/default-avatar.png'}}"></image>
          <view class="user-details">
            <view class="nickname">{{userInfo.nickName || '猫咪用户'}}</view>
            <view class="points">当前碎片: {{userInfo.points || 0}}</view>
          </view>
        </view>
        <view class="checkin-stats">
          <view class="stat-item">
            <view class="stat-value">{{checkInDays}}</view>
            <view class="stat-label">累计签到</view>
          </view>
          <view class="stat-item">
            <view class="stat-value">{{consecutiveDays}}</view>
            <view class="stat-label">连续签到</view>
          </view>
        </view>
      </view>

      <!-- 签到按钮 -->
      <view class="checkin-button-container">
        <view class="checkin-button {{todayChecked ? 'checked' : ''}} {{checkInAnimation ? 'animate' : ''}}" 
              bindtap="handleCheckIn" 
              bindanimationend="onAnimationEnd">
          <view class="button-inner">
            <view class="button-text">{{todayChecked ? '已签到' : '签到'}}</view>
            <view class="button-subtext">{{todayChecked ? '明天再来' : '+5碎片'}}</view>
          </view>
        </view>
      </view>

      <!-- 日历签到记录 -->
      <view class="calendar-container">
        <view class="calendar-header">
          <view class="calendar-title">{{currentYear}}年{{currentMonth}}月</view>
        </view>
        <view class="weekday-header">
          <view class="weekday-item" wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="index">{{item}}</view>
        </view>
        <view class="calendar-days">
          <view class="day-item {{item.disabled ? 'disabled' : ''}} {{item.checked ? 'checked' : ''}} {{item.isToday ? 'today' : ''}}"
                wx:for="{{calendarDays}}" 
                wx:key="index">
            <view class="day-number" wx:if="{{!item.disabled}}">{{item.day}}</view>
          </view>
        </view>
      </view>

      <!-- 连续签到奖励 -->
      <view class="rewards-container">
        <view class="rewards-title">连续签到奖励</view>
        <view class="rewards-list">
          <view class="reward-item {{item.status}}" wx:for="{{rewards}}" wx:key="day">
            <view class="reward-day">{{item.day}}天</view>
            <view class="reward-points">+{{item.points}}</view>
            <view class="reward-status">
              <view class="status-icon completed" wx:if="{{item.status === 'completed'}}">✓</view>
              <view class="status-icon current" wx:elif="{{item.status === 'current'}}">今</view>
            </view>
          </view>
        </view>
      </view>

      <!-- 签到规则 -->
      <view class="rules-container">
        <view class="rules-title">签到规则</view>
        <view class="rules-content">
          <view class="rule-item">1. 每日签到可获得1碎片</view>
          <view class="rule-item">2. 连续签到可获得额外奖励</view>
          <view class="rule-item">3. 碎片可在"兑换"页面兑换礼品</view>
          <view class="rule-item">4. 每日0点重置签到状态</view>
        </view>
      </view>
    </block>
  </block>
</view>
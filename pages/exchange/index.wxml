<view class="exchange-container">
  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." inherit-color />
  </view>

  <block wx:else>
    <!-- 顶部用户信息 -->
    <view class="user-info-bar">
      <view class="user-points" wx:if="{{isLogin}}">
        <text class="points-label">我的碎片</text>
        <text class="points-value">{{userInfo.points || 0}}</text>
      </view>
      <view class="login-tip" wx:else>
        <text>登录后查看我的碎片</text>
        <text class="login-btn" bindtap="goToLogin">去登录</text>
      </view>
      <view class="history-btn" bindtap="viewExchangeHistory">
        <text>兑换记录</text>
        <t-icon name="chevron-right" size="40rpx" color="#999" />
      </view>
    </view>

    <!-- 兑换商品列表 -->
    <view class="exchange-list">
      <view class="exchange-item" 
            wx:for="{{exchangeItems}}" 
            wx:key="_id" 
            data-id="{{item._id}}" 
            bindtap="handleItemClick">
        <image class="item-image" src="{{item.image || '/assets/images/exchange/default.png'}}" mode="aspectFill" />
        <view class="item-stock {{item.stock <= 0 ? 'out-of-stock' : ''}}">
          {{item.stock <= 0 ? '已抢光' : '库存: ' + item.stock}}
        </view>
        <view class="item-info">
          <view class="item-title">{{item.title}}</view>
          <view class="item-price-row">
            <view class="item-points">{{item.points}}碎片</view>
            <view class="item-original-price" wx:if="{{item.originPrice}}">{{item.originPrice}}</view>
          </view>
          <view class="item-sold">已兑换{{item.sold || 0}}件</view>
          <view class="exchange-btn {{(!isLogin || userInfo.points < item.points || item.stock <= 0) ? 'disabled' : ''}}" 
                catchtap="handleExchange" 
                data-id="{{item._id}}">
            {{item.stock <= 0 ? '已抢光' : ((!isLogin || userInfo.points < item.points) ? '碎片不足' : '立即兑换')}}
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{exchangeItems.length === 0}}">
      <image class="empty-image" src="/assets/images/empty.png" />
      <view class="empty-text">暂无兑换商品</view>
    </view>

    <!-- 兑换说明 -->
    <view class="exchange-rules">
      <view class="rules-title">兑换说明</view>
      <view class="rules-content">
        <view class="rule-item">1. 碎片可通过签到、完成任务等方式获取</view>
        <view class="rule-item">2. 兑换后需填写收货地址</view>
        <view class="rule-item">3. 兑换记录可在"兑换记录"中查看</view>
        <view class="rule-item">4. 如有疑问，请联系客服</view>
      </view>
    </view>
  </block>
</view>
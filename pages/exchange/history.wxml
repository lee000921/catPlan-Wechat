<view class="history-container">
  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." inherit-color />
  </view>

  <block wx:else>
    <!-- 未登录状态 -->
    <view class="not-login" wx:if="{{!isLogin}}">
      <view class="login-tips">登录后查看兑换记录</view>
      <t-button theme="primary" size="large" bind:tap="goToLogin">去登录</t-button>
    </view>

    <!-- 已登录状态 -->
    <block wx:else>
      <!-- 兑换记录列表 -->
      <view class="records-list" wx:if="{{exchangeRecords.length > 0}}">
        <view class="record-item" wx:for="{{exchangeRecords}}" wx:key="_id">
          <view class="record-header">
            <view class="record-time">{{item.exchangeTime ? wxs.formatDate(item.exchangeTime) : ''}}</view>
          </view>

          <view class="record-content">
            <image class="item-image" src="{{item.goodImage || '/assets/images/exchange/default.png'}}" mode="aspectFill" />
            <view class="item-info">
              <view class="item-title">{{item.goodTitle}}</view>
              <view class="item-points">{{item.points}}碎片</view>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:else>
        <image class="empty-image" src="/assets/images/empty.png" />
        <view class="empty-text">暂无兑换记录</view>
      </view>
    </block>
  </block>
</view>

<!-- WXS 模块用于格式化日期 -->
<wxs module="wxs">
  function formatDate(dateStr) {
    if (!dateStr) return '';
    
    // 将日期字符串转换为可读格式
    var date = getDate(dateStr);
    var year = date.getFullYear();
    var month = padZero(date.getMonth() + 1);
    var day = padZero(date.getDate());
    var hour = padZero(date.getHours());
    var minute = padZero(date.getMinutes());
    
    return year + '-' + month + '-' + day + ' ' + hour + ':' + minute;
  }
  
  function padZero(num) {
    return num < 10 ? '0' + num : '' + num;
  }
  
  module.exports = {
    formatDate: formatDate
  };
</wxs>
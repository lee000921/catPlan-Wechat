/* pages/shop/detail/detail.wxss */
page {
  background-color: #f5f6f7;
}

.container {
  padding-bottom: 160rpx;
}

/* ========== 商品图片 ========== */
.product-image-wrapper {
  position: relative;
  width: 100%;
  height: 560rpx;
  background-color: #ffffff;
}

.product-image {
  width: 100%;
  height: 100%;
}

.image-overlay {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  right: 24rpx;
  display: flex;
  justify-content: flex-end;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  background-color: rgba(82, 196, 26, 0.95);
  color: #ffffff;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 4rpx 16rpx rgba(82, 196, 26, 0.3);
}

.status-badge.out-of-stock {
  background-color: rgba(153, 153, 153, 0.95);
  box-shadow: 0 4rpx 16rpx rgba(153, 153, 153, 0.3);
}

.status-icon {
  margin-right: 6rpx;
  font-weight: 700;
}

/* ========== 信息卡片 ========== */
.info-card {
  background-color: #ffffff;
  margin: -40rpx 24rpx 24rpx;
  position: relative;
  z-index: 10;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.product-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.product-name {
  flex: 1;
  font-size: 38rpx;
  font-weight: 700;
  color: #333333;
  margin-right: 24rpx;
  line-height: 1.3;
}

.points-tag {
  background: linear-gradient(135deg, #ff976a 0%, #ff7849 100%);
  color: #ffffff;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: baseline;
  box-shadow: 0 4rpx 16rpx rgba(255, 151, 106, 0.3);
}

.points-value {
  font-size: 42rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.points-unit {
  font-size: 24rpx;
  margin-left: 6rpx;
  opacity: 0.9;
}

.product-meta-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #f0f0f0;
}

.meta-item {
  display: flex;
  align-items: center;
  justify-content: center;
}

.meta-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.meta-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.meta-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 4rpx;
}

.meta-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
}

/* ========== 章节卡片 ========== */
.section-card {
  background-color: #ffffff;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

.desc-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  white-space: pre-wrap;
  display: block;
}

/* ========== 规则列表 ========== */
.rules-list {
  margin-top: 16rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
}

.rule-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #1989fa;
  border-radius: 50%;
  margin-right: 16rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.rule-text {
  flex: 1;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

/* ========== 积分卡片 ========== */
.points-card {
  background: linear-gradient(135deg, #1989fa 0%, #3699ff 100%);
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(25, 137, 250, 0.3);
}

.points-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.points-card-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.current-points {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -1rpx;
}

.points-calc {
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  backdrop-filter: blur(10rpx);
}

.calc-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.calc-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.calc-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #52c41a;
  background-color: rgba(255, 255, 255, 0.9);
  padding: 8rpx 20rpx;
  border-radius: 10rpx;
}

/* ========== 底部操作栏 ========== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.history-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 48rpx;
}

.history-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.history-text {
  font-size: 22rpx;
  color: #999999;
}

.exchange-btn {
  flex: 1;
  background: linear-gradient(135deg, #1989fa 0%, #3699ff 100%);
  color: #ffffff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(25, 137, 250, 0.35);
}

.exchange-btn:active {
  transform: scale(0.98);
}

.exchange-btn-text {
  display: block;
}

.exchange-btn-disabled {
  flex: 1;
  background-color: #f5f5f5;
  color: #999999;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 16rpx;
  font-size: 32rpx;
}

/* ========== 加载状态 ========== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #f5f6f7;
}

.loading-spinner {
  width: 72rpx;
  height: 72rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #1989fa;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 28rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #999999;
  font-size: 28rpx;
}

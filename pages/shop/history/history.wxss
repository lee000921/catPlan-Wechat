/* pages/shop/history/history.wxss */
page {
  background-color: #f5f6f7;
}

.container {
  padding: 24rpx;
  padding-bottom: 180rpx;
}

/* ========== 头部卡片 ========== */
.header-card {
  background: linear-gradient(135deg, #1989fa 0%, #3699ff 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(25, 137, 250, 0.3);
}

.header-content {
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.header-stats {
  display: flex;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.15);
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
  backdrop-filter: blur(10rpx);
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -1rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

/* ========== 兑换列表 ========== */
.exchange-list {
  margin-top: 8rpx;
}

/* ========== 加载状态 ========== */
.loading-state,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #1989fa;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

.loading-spinner.small {
  width: 40rpx;
  height: 40rpx;
  border-width: 3rpx;
  margin-bottom: 12rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #999999;
  font-size: 28rpx;
}

/* ========== 空状态 ========== */
.empty-illustration {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.8;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #666666;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.go-shop-btn {
  background: linear-gradient(135deg, #1989fa 0%, #3699ff 100%);
  color: #ffffff;
  padding: 24rpx 64rpx;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(25, 137, 250, 0.35);
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
}

/* ========== 兑换卡片 ========== */
.exchange-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.status-wrapper {
  display: flex;
  flex-direction: column;
}

.status-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.status-tag.success {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.status-tag.pending {
  background-color: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

.status-tag.failed {
  background-color: rgba(255, 77, 79, 0.1);
  color: #ff4d4f;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: currentColor;
  margin-right: 8rpx;
}

.create-time {
  font-size: 24rpx;
  color: #999999;
}

.order-no {
  font-size: 22rpx;
  color: #999999;
}

/* ========== 卡片主体 ========== */
.card-body {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.product-image-wrapper {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #f8f9fa;
  flex-shrink: 0;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  line-height: 1.4;
}

.product-meta {
  display: flex;
  align-items: center;
}

.points-badge {
  display: flex;
  align-items: baseline;
  background: linear-gradient(135deg, #ff976a 0%, #ff7849 100%);
  color: #ffffff;
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
  margin-right: 16rpx;
}

.points-value {
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.points-unit {
  font-size: 22rpx;
  margin-left: 4rpx;
  opacity: 0.9;
}

.quantity {
  font-size: 26rpx;
  color: #999999;
}

/* ========== 卡片底部 ========== */
.card-footer {
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.footer-tip {
  display: flex;
  align-items: center;
}

.tip-icon {
  width: 28rpx;
  height: 28rpx;
  background-color: #52c41a;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 700;
  margin-right: 12rpx;
}

.footer-tip text:last-child {
  font-size: 24rpx;
  color: #52c41a;
}

/* ========== 加载更多 ========== */
.loading-more,
.no-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 24rpx;
}

.no-more text {
  position: relative;
  padding: 0 32rpx;
  background-color: #f5f6f7;
}

.no-more text::before,
.no-more text::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 40rpx;
  height: 1rpx;
  background-color: #e0e0e0;
}

.no-more text::before {
  right: 100%;
  margin-right: 16rpx;
}

.no-more text::after {
  left: 100%;
  margin-left: 16rpx;
}

/* ========== 联系客服 ========== */
.contact-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.contact-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f6f7;
  color: #333333;
  padding: 24rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.contact-btn:active {
  background-color: #e8e9eb;
}

.contact-icon {
  margin-right: 12rpx;
  font-size: 34rpx;
}

.contact-text {
  display: block;
}

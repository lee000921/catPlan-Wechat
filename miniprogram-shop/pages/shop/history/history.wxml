<!--pages/shop/history/history.wxml-->
<view class="container">
  <!-- 顶部统计 -->
  <view class="header-card">
    <view class="header-content">
      <text class="header-title">兑换记录</text>
      <text class="header-subtitle">查看您的所有兑换历史</text>
    </view>
    <view class="header-stats">
      <view class="stat-item">
        <text class="stat-value">{{total}}</text>
        <text class="stat-label">次兑换</text>
      </view>
    </view>
  </view>

  <!-- 兑换列表 -->
  <view class="exchange-list">
    <!-- 加载状态 -->
    <view wx:if="{{loading && exchangeList.length === 0}}" class="loading-state">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在加载记录...</text>
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{exchangeList.length === 0}}" class="empty-state" bindtap="goBack">
      <view class="empty-illustration">📜</view>
      <text class="empty-title">暂无兑换记录</text>
      <text class="empty-desc">去商城看看有什么可兑换的吧</text>
      <view class="go-shop-btn">
        <text class="btn-text">前往商城</text>
      </view>
    </view>

    <!-- 列表内容 -->
    <view wx:else class="list-container">
      <view 
        class="exchange-card" 
        wx:for="{{exchangeList}}" 
        wx:key="id"
        bindtap="viewDetail"
        data-id="{{item.productId}}"
      >
        <view class="card-header">
          <view class="status-wrapper">
            <view class="status-tag {{item.status === 'success' ? 'success' : item.status === 'pending' ? 'pending' : 'failed'}}">
              <view class="status-dot"></view>
              <text>{{item.statusText || (item.status === 'success' ? '兑换成功' : item.status === 'pending' ? '处理中' : '兑换失败')}}</text>
            </view>
            <text class="create-time">{{item.createTime}}</text>
          </view>
          <text class="order-no">订单号：{{item.orderNo}}</text>
        </view>

        <view class="card-body">
          <view class="product-image-wrapper">
            <image class="product-image" src="{{item.productImage || '/images/default-product.png'}}" mode="aspectFill"></image>
          </view>
          <view class="product-info">
            <text class="product-name">{{item.productName}}</text>
            <view class="product-meta">
              <view class="points-badge">
                <text class="points-value">-{{item.points}}</text>
                <text class="points-unit">积分</text>
              </view>
              <text class="quantity">× {{item.count}}</text>
            </view>
          </view>
        </view>

        <view class="card-footer" wx:if="{{item.status === 'success'}}">
          <view class="footer-tip">
            <text class="tip-icon">✓</text>
            <text>兑换成功，请联系管理员领取</text>
          </view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{loading && exchangeList.length > 0}}" class="loading-more">
        <view class="loading-spinner small"></view>
        <text>加载中...</text>
      </view>
      <view wx:if="{{!hasMore && exchangeList.length > 0}}" class="no-more">
        <text>— 没有更多记录了 —</text>
      </view>
    </view>
  </view>

  <!-- 底部联系客服 -->
  <view class="contact-section" wx:if="{{exchangeList.length > 0}}">
    <view class="contact-btn" bindtap="contactSeller">
      <text class="contact-icon">📞</text>
      <text class="contact-text">联系客服</text>
    </view>
  </view>
</view>

/* 商城兑换页样式 - 蓝色系设计 */
.container {
  padding: 24rpx;
  padding-bottom: 180rpx;
  background: #f0f5ff;
}

/* 商品信息卡片 */
.product-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(24, 144, 255, 0.08);
}

.product-header {
  display: flex;
  align-items: center;
}

.product-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  background-color: #f5f7fa;
}

.product-info {
  flex: 1;
  margin-left: 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.product-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 16rpx;
}

.product-points {
  display: flex;
  align-items: baseline;
}

.product-points .points-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6b35;
  margin-right: 8rpx;
}

.points-unit {
  font-size: 26rpx;
  color: #ff6b35;
}

/* 数量选择 */
.quantity-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(24, 144, 255, 0.08);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 20rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
  justify-content: center;
}

.quantity-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f0f5ff, #e6f7ff);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #1890ff;
}

.quantity-btn:active {
  background: #d6e4ff;
}

.btn-text {
  font-size: 40rpx;
  color: #1890ff;
  font-weight: 600;
}

.quantity-input {
  width: 120rpx;
  height: 80rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #262626;
  margin: 0 20rpx;
  border: 2rpx solid #e6f7ff;
  border-radius: 12rpx;
  background: #fafafa;
}

.quantity-tips {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 0 20rpx;
}

.quantity-tips text {
  font-size: 24rpx;
  color: #8c8c8c;
}

/* 积分明细 */
.points-detail {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(24, 144, 255, 0.08);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-row.total {
  margin-top: 8rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #e6f7ff;
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #595959;
}

.detail-value {
  font-size: 28rpx;
  color: #262626;
  font-weight: 500;
}

.total-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b35;
}

/* 用户积分 */
.user-points {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(24, 144, 255, 0.08);
}

.points-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.points-row.after {
  border-top: 1rpx dashed #e6f7ff;
  padding-top: 16rpx;
}

.points-label {
  font-size: 28rpx;
  color: #595959;
}

.points-value.current {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b35;
}

.points-value.after {
  font-size: 36rpx;
  font-weight: bold;
  color: #52c41a;
}

.points-value.after.warning {
  color: #ff4d4f;
}

/* 兑换说明 */
.notice {
  background: linear-gradient(135deg, #fff7e6, #fffbf0);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(255, 193, 7, 0.3);
}

.notice-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.notice-item:last-child {
  margin-bottom: 0;
}

.notice-icon {
  color: #1890ff;
  margin-right: 12rpx;
  font-size: 28rpx;
}

.notice-text {
  flex: 1;
  font-size: 26rpx;
  color: #595959;
  line-height: 1.6;
}

/* 底部确认栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background-color: white;
  box-shadow: 0 -2rpx 12rpx rgba(24, 144, 255, 0.08);
  z-index: 100;
}

.total-info {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: #595959;
  margin-right: 8rpx;
}

.total-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #ff6b35;
}

.total-unit {
  font-size: 26rpx;
  color: #ff6b35;
  margin-left: 4rpx;
}

.confirm-btn {
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  color: white;
  padding: 28rpx 60rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.3);
}

.confirm-btn:active {
  transform: translateY(2rpx);
}

.confirm-btn.disabled {
  background: #d9d9d9;
  color: #bfbfbf;
  box-shadow: none;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  background: #f0f5ff;
}

.loading-text {
  color: #8c8c8c;
  font-size: 28rpx;
}

/* 权限不足 */
.permission-denied {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: #f0f5ff;
}

.denied-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.denied-text {
  font-size: 32rpx;
  color: #8c8c8c;
}
.denied-text {
  font-size: 32rpx;
  color: #8c8c8c;
}

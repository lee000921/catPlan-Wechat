<!--pages/shop/exchange/exchange.wxml-->
<view class="container" wx:if="{{!loading && product}}">
  <!-- 商品信息卡片 -->
  <view class="product-card card">
    <view class="product-header">
      <image class="product-image" src="{{product.imageUrl || '/images/default-product.png'}}" mode="aspectFill"></image>
      <view class="product-info">
        <text class="product-name">{{product.name}}</text>
        <view class="product-points">
          <text class="points-value">{{product.points}}</text>
          <text class="points-unit">积分/件</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 兑换数量选择 -->
  <view class="quantity-section card">
    <view class="section-title">兑换数量</view>
    <view class="quantity-control">
      <view 
        class="quantity-btn" 
        data-type="minus"
        bindtap="changeCount"
      >
        <text class="btn-text">−</text>
      </view>
      <input 
        class="quantity-input" 
        type="number" 
        value="{{exchangeCount}}" 
        bindinput="inputCount"
      />
      <view 
        class="quantity-btn" 
        data-type="add"
        bindtap="changeCount"
      >
        <text class="btn-text">+</text>
      </view>
    </view>
    <view class="quantity-tips">
      <text wx:if="{{product.limitPerUser}}">每人限兑{{product.limitPerUser}}件</text>
      <text wx:if="{{product.stock}}">当前库存：{{product.stock}}件</text>
    </view>
  </view>

  <!-- 积分明细 -->
  <view class="points-detail card">
    <view class="section-title">积分明细</view>
    <view class="detail-row">
      <text class="detail-label">单价</text>
      <text class="detail-value">{{product.points}} 积分</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">数量</text>
      <text class="detail-value">x {{exchangeCount}}</text>
    </view>
    <view class="detail-row total">
      <text class="detail-label">共需</text>
      <text class="detail-value total-value">{{product.points * exchangeCount}} 积分</text>
    </view>
  </view>

  <!-- 用户当前积分 -->
  <view class="user-points card">
    <view class="points-row">
      <text class="points-label">我的积分</text>
      <text class="points-value current">{{points}}</text>
    </view>
    <view class="points-row after">
      <text class="points-label">兑换后剩余</text>
      <text class="points-value after {{points - product.points * exchangeCount < 0 ? 'warning' : ''}}">
        {{points - product.points * exchangeCount}}
      </text>
    </view>
  </view>

  <!-- 兑换说明 -->
  <view class="notice card">
    <view class="section-title">兑换须知</view>
    <view class="notice-item">
      <text class="notice-icon">✓</text>
      <text class="notice-text">仅 A 类用户（申请者）可兑换</text>
    </view>
    <view class="notice-item">
      <text class="notice-icon">✓</text>
      <text class="notice-text">兑换后积分立即扣除，不可恢复</text>
    </view>
    <view class="notice-item">
      <text class="notice-icon">✓</text>
      <text class="notice-text">兑换成功后请联系管理员领取</text>
    </view>
  </view>

  <!-- 底部确认按钮 -->
  <view class="bottom-bar">
    <view class="total-info">
      <text class="total-label">总计</text>
      <text class="total-value">{{product.points * exchangeCount}}</text>
      <text class="total-unit">积分</text>
    </view>
    <view 
      class="confirm-btn {{canExchange && !submitting ? '' : 'disabled'}}"
      bindtap="confirmExchange"
    >
      <text wx:if="{{!submitting}}">确认兑换</text>
      <text wx:else>兑换中...</text>
    </view>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-container" wx:if="{{loading}}">
  <text class="loading-text">加载中...</text>
</view>

<!-- 权限不足提示 -->
<view class="permission-denied" wx:if="{{!isTypeA && !loading}}">
  <text class="denied-icon">⚠️</text>
  <text class="denied-text">仅 A 类用户可兑换</text>
</view>

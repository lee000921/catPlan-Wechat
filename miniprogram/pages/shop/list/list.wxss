/* 商城列表页样式 - 蓝色系设计 */
page {
  background-color: #f0f5ff;
}

.container {
  padding: 24rpx;
  padding-bottom: 40rpx;
}

/* 用户信息栏 */
.user-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(24, 144, 255, 0.25);
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar-wrapper {
  position: relative;
  margin-right: 20rpx;
}

.avatar,
.avatar-placeholder {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar {
  background-color: #ffffff;
}

.avatar-placeholder {
  background-color: rgba(255, 255, 255, 0.2);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.user-tags {
  margin-top: 8rpx;
}

.user-type-tag {
  font-size: 22rpx;
  color: #ffffff;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  display: inline-block;
}

.points-card {
  text-align: center;
  background-color: rgba(255, 255, 255, 0.15);
  padding: 16rpx 28rpx;
  border-radius: 20rpx;
}

.points-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
  margin-bottom: 4rpx;
}

.points-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
}

/* 商品区域 */
.product-section {
  margin-top: 12rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #262626;
}

.section-count {
  font-size: 24rpx;
  color: #8c8c8c;
}

/* 加载状态 */
.loading-state,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e6f7ff;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

.loading-spinner.small {
  width: 40rpx;
  height: 40rpx;
  border-width: 3rpx;
  margin-bottom: 12rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #8c8c8c;
  font-size: 28rpx;
}

/* 空状态 */
.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.8;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #595959;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #8c8c8c;
}

/* 商品网格 */
.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.product-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(24, 144, 255, 0.08);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.product-card:active {
  transform: scale(0.98);
}

.product-image-wrapper {
  position: relative;
  width: 100%;
  height: 320rpx;
  background-color: #f5f7fa;
}

.product-image {
  width: 100%;
  height: 100%;
}

.stock-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background-color: rgba(24, 144, 255, 0.9);
  color: #ffffff;
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
}

.product-content {
  padding: 24rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #262626;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  line-height: 1.4;
}

.product-desc {
  font-size: 22rpx;
  color: #8c8c8c;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-top: 12rpx;
  line-height: 1.5;
}

.product-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.points-info {
  display: flex;
  align-items: baseline;
}

.points-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #ff6b35;
}

.points-unit {
  font-size: 22rpx;
  color: #ff6b35;
  margin-left: 4rpx;
}

.exchange-btn-wrapper {
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  color: #ffffff;
  padding: 12rpx 28rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.25);
}

.exchange-btn-text {
  font-size: 24rpx;
  font-weight: 600;
}

.exchange-btn-disabled {
  background-color: #f5f5f5;
  color: #bfbfbf;
  padding: 12rpx 28rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

/* 加载更多 */
.loading-more,
.no-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  color: #8c8c8c;
  font-size: 24rpx;
}

/* 底部提示 */
.bottom-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fff7e6;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-top: 32rpx;
}

.tip-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.bottom-tip text:last-child {
  font-size: 24rpx;
  color: #fa8c16;
}

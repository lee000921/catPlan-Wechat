/* pages/shop/list/list.wxss */
.container {
  padding-bottom: 40rpx;
}

/* 用户信息栏 */
.user-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar,
.avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.avatar {
  background-color: #e0e0e0;
}

.avatar-placeholder {
  background-color: #4A90D9;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.user-type {
  font-size: 24rpx;
  color: #4A90D9;
  margin-top: 4rpx;
  background-color: rgba(74, 144, 217, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.points-info {
  text-align: right;
}

.points-label {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.points-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6b35;
}

/* 商品列表 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin: 20rpx 0;
  padding-left: 10rpx;
}

.loading-container,
.empty-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-text,
.empty-text {
  color: #999;
  font-size: 28rpx;
}

.product-grid {
  display: flex;
  flex-direction: column;
}

.product-item {
  display: flex;
  padding: 20rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.product-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background-color: #f5f5f5;
}

.product-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.product-desc {
  font-size: 24rpx;
  color: #666;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-top: 8rpx;
}

.product-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.product-points {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b35;
  margin-right: 20rpx;
}

.product-stock {
  font-size: 24rpx;
  color: #999;
}

.product-status {
  margin-top: 12rpx;
}

.status-tag {
  font-size: 22rpx;
  color: #52c41a;
  background-color: rgba(82, 196, 26, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.status-tag.out-of-stock {
  color: #999;
  background-color: #f5f5f5;
}

.exchange-btn {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  background-color: #4A90D9;
  color: white;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

.exchange-btn:active {
  background-color: #3a7bc8;
}

.exchange-btn-disabled {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  background-color: #f5f5f5;
  color: #999;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

/* 加载更多 */
.loading-more,
.no-more {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 底部提示 */
.bottom-tip {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 24rpx;
}

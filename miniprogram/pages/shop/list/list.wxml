<!--pages/shop/list/list.wxml-->
<view class="container">
  <!-- 顶部用户信息栏 -->
  <view class="user-bar">
    <view class="user-info">
      <view class="avatar-wrapper">
        <image class="avatar" wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <view class="avatar-placeholder" wx:else>{{userInfo.nickname ? userInfo.nickname[0] : 'U'}}</view>
      </view>
      <view class="user-detail">
        <text class="nickname">{{userInfo.nickname || '用户'}}</text>
        <view class="user-tags">
          <text class="user-type-tag" wx:if="{{isTypeA}}">A 类用户</text>
        </view>
      </view>
    </view>
    <view class="points-card">
      <text class="points-label">我的积分</text>
      <text class="points-value">{{points || 0}}</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="product-section">
    <view class="section-header">
      <text class="section-title">可兑换物品</text>
      <text class="section-count" wx:if="{{productList.length > 0}}">{{productList.length}} 件物品</text>
    </view>
    
    <!-- 加载状态 -->
    <view wx:if="{{loading && productList.length === 0}}" class="loading-state">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在加载好物...</text>
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{productList.length === 0}}" class="empty-state">
      <view class="empty-icon">🎁</view>
      <text class="empty-title">暂无可兑换物品</text>
      <text class="empty-desc">稍后再来看看吧</text>
    </view>

    <!-- 商品网格 -->
    <view wx:else class="product-grid">
      <view 
        class="product-card" 
        wx:for="{{productList}}" 
        wx:key="id"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <view class="product-image-wrapper">
          <image class="product-image" src="{{item.imageUrl || '/images/default-product.png'}}" mode="aspectFill"></image>
          <view class="stock-tag" wx:if="{{item.stock !== null && item.stock !== undefined}}">
            <text wx:if="{{item.stock > 0}}">库存 {{item.stock}}</text>
            <text wx:else>已兑完</text>
          </view>
        </view>
        
        <view class="product-content">
          <text class="product-name">{{item.name}}</text>
          <text class="product-desc" wx:if="{{item.description}}">{{item.description}}</text>
          
          <view class="product-footer">
            <view class="points-info">
              <text class="points-value">{{item.points}}</text>
              <text class="points-unit">积分</text>
            </view>
            <view 
              class="exchange-btn-wrapper"
              catchtap="exchangeNow"
              data-id="{{item.id}}"
              wx:if="{{isTypeA && item.stock > 0}}"
            >
              <text class="exchange-btn-text">兑换</text>
            </view>
            <view class="exchange-btn-disabled" wx:elif="{{!isTypeA}}">
              <text>A 类专享</text>
            </view>
            <view class="exchange-btn-disabled" wx:elif="{{item.stock <= 0}}">
              <text>已兑完</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多提示 -->
    <view wx:if="{{loading && productList.length > 0}}" class="loading-more">
      <view class="loading-spinner small"></view>
      <text>加载中...</text>
    </view>
    <view wx:if="{{!hasMore && productList.length > 0}}" class="no-more">
      <text>— 没有更多了 —</text>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="bottom-tip" wx:if="{{!isTypeA}}">
    <text class="tip-icon">ℹ️</text>
    <text>仅 A 类用户（申请者）可兑换</text>
  </view>
</view>

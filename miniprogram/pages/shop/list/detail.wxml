<!--pages/shop/detail/detail.wxml-->
<view class="container" wx:if="{{!loading && product}}">
  <!-- 商品图片 -->
  <view class="product-image-wrapper">
    <image 
      class="product-image" 
      src="{{product.imageUrl || '/images/default-product.png'}}" 
      mode="aspectFill"
    ></image>
    <view class="image-overlay">
      <view class="status-badge" wx:if="{{product.stock > 0}}">
        <text class="status-icon">✓</text>
        <text>可兑换</text>
      </view>
      <view class="status-badge out-of-stock" wx:else>
        <text>已兑完</text>
      </view>
    </view>
  </view>

  <!-- 商品信息卡片 -->
  <view class="info-card">
    <view class="product-header">
      <text class="product-name">{{product.name}}</text>
      <view class="points-tag">
        <text class="points-value">{{product.points}}</text>
        <text class="points-unit">积分</text>
      </view>
    </view>

    <view class="product-meta-grid">
      <view class="meta-item" wx:if="{{product.stock !== null}}">
        <view class="meta-icon">📦</view>
        <view class="meta-content">
          <text class="meta-label">库存</text>
          <text class="meta-value">{{product.stock}}</text>
        </view>
      </view>
      <view class="meta-item" wx:if="{{product.exchangeCount !== null}}">
        <view class="meta-icon">🔥</view>
        <view class="meta-content">
          <text class="meta-label">已兑换</text>
          <text class="meta-value">{{product.exchangeCount}}</text>
        </view>
      </view>
      <view class="meta-item" wx:if="{{product.limitPerUser}}">
        <view class="meta-icon">👤</view>
        <view class="meta-content">
          <text class="meta-label">限兑</text>
          <text class="meta-value">{{product.limitPerUser}}件/人</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 商品描述 -->
  <view class="section-card" wx:if="{{product.description}}">
    <view class="section-header">
      <text class="section-icon">📝</text>
      <text class="section-title">商品详情</text>
    </view>
    <text class="desc-text">{{product.description}}</text>
  </view>

  <!-- 兑换说明 -->
  <view class="section-card">
    <view class="section-header">
      <text class="section-icon">📋</text>
      <text class="section-title">兑换说明</text>
    </view>
    <view class="rules-list">
      <view class="rule-item">
        <view class="rule-dot"></view>
        <text class="rule-text">仅 A 类用户（申请者）可兑换</text>
      </view>
      <view class="rule-item">
        <view class="rule-dot"></view>
        <text class="rule-text">兑换后积分将立即扣除</text>
      </view>
      <view class="rule-item" wx:if="{{product.limitPerUser}}">
        <view class="rule-dot"></view>
        <text class="rule-text">每人限兑{{product.limitPerUser}}件</text>
      </view>
      <view class="rule-item">
        <view class="rule-dot"></view>
        <text class="rule-text">兑换成功后请联系管理员领取</text>
      </view>
    </view>
  </view>

  <!-- 用户积分信息 -->
  <view class="points-card">
    <view class="points-header">
      <text class="points-card-title">我的积分</text>
      <text class="current-points">{{points}}</text>
    </view>
    <view class="points-calc" wx:if="{{isTypeA && points >= product.points}}">
      <view class="calc-row">
        <text class="calc-label">兑换后剩余</text>
        <text class="calc-value">{{points - product.points}}</text>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="history-btn" bindtap="goToHistory">
      <view class="history-icon">📜</view>
      <text class="history-text">记录</text>
    </view>
    <view 
      class="exchange-btn" 
      wx:if="{{isTypeA && product.stock > 0}}"
      bindtap="exchangeNow"
    >
      <text class="exchange-btn-text">立即兑换</text>
    </view>
    <view class="exchange-btn-disabled" wx:elif="{{!isTypeA}}">
      <text>A 类专享</text>
    </view>
    <view class="exchange-btn-disabled" wx:elif="{{product.stock <= 0}}">
      <text>已兑完</text>
    </view>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-container" wx:if="{{loading}}">
  <view class="loading-spinner"></view>
  <text class="loading-text">正在加载...</text>
</view>

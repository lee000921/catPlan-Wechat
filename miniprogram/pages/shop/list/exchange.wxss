/* pages/shop/exchange/exchange.wxss */
page {
  background-color: #f5f6f7;
}

.container {
  padding: 24rpx;
  padding-bottom: 180rpx;
}

/* ========== 商品信息卡片 ========== */
.product-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.product-header {
  display: flex;
  align-items: center;
}

.image-wrapper {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #f8f9fa;
  flex-shrink: 0;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-info {
  flex: 1;
  margin-left: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.product-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.points-display {
  display: flex;
  align-items: baseline;
  background: linear-gradient(135deg, #ff976a 0%, #ff7849 100%);
  color: #ffffff;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  align-self: flex-start;
}

.points-value {
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.points-unit {
  font-size: 22rpx;
  margin-left: 6rpx;
  opacity: 0.9;
}

/* ========== 章节卡片 ========== */
.section-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

/* ========== 数量控制 ========== */
.quantity-control {
  display: flex;
  align-items: center;
  justify-content: center;
}

.quantity-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.quantity-btn.minus {
  background-color: #f5f6f7;
}

.quantity-btn.plus {
  background: linear-gradient(135deg, #1989fa 0%, #3699ff 100%);
}

.quantity-btn:active {
  transform: scale(0.95);
}

.btn-text {
  font-size: 44rpx;
  color: #333333;
  font-weight: 300;
  line-height: 1;
}

.quantity-btn.plus .btn-text {
  color: #ffffff;
}

.quantity-display {
  display: flex;
  align-items: center;
  margin: 0 32rpx;
}

.quantity-input {
  width: 120rpx;
  height: 88rpx;
  text-align: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  background-color: #f8f9fa;
  border: none;
  border-radius: 12rpx;
}

.quantity-label {
  font-size: 26rpx;
  color: #999999;
  margin-left: 12rpx;
}

.quantity-tips {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 0 8rpx;
}

.quantity-tips text {
  font-size: 24rpx;
  color: #999999;
}

/* ========== 积分明细 ========== */
.detail-list {
  margin-top: 8rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #666666;
}

.detail-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.total-row {
  margin-top: 8rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
  border-bottom: none;
}

.total-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.total-display {
  display: flex;
  align-items: baseline;
}

.total-value {
  font-size: 42rpx;
  font-weight: 700;
  color: #ff976a;
  letter-spacing: -1rpx;
}

.total-unit {
  font-size: 26rpx;
  color: #ff976a;
  margin-left: 8rpx;
}

/* ========== 积分汇总卡片 ========== */
.points-summary-card {
  background: linear-gradient(135deg, #1989fa 0%, #3699ff 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(25, 137, 250, 0.3);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.summary-row.after {
  border-top: 1rpx dashed rgba(255, 255, 255, 0.3);
  margin-top: 8rpx;
  padding-top: 20rpx;
}

.summary-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.summary-value {
  font-size: 38rpx;
  font-weight: 700;
}

.summary-value.current {
  color: #ffffff;
}

.summary-value.after {
  color: #52c41a;
  background-color: rgba(255, 255, 255, 0.95);
  padding: 8rpx 20rpx;
  border-radius: 10rpx;
}

.summary-value.after.warning {
  color: #ff4d4f;
}

/* ========== 兑换说明卡片 ========== */
.notice-card {
  background-color: #fff7e6;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.notice-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.notice-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #ff976a;
}

.notice-list {
  margin-top: 8rpx;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}

.notice-check {
  width: 32rpx;
  height: 32rpx;
  background-color: #1989fa;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  margin-right: 16rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.notice-text {
  flex: 1;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

/* ========== 底部确认栏 ========== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.total-summary {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: #666666;
  margin-right: 12rpx;
}

.total-amount {
  display: flex;
  align-items: baseline;
}

.total-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #ff976a;
  letter-spacing: -1rpx;
}

.total-unit {
  font-size: 26rpx;
  color: #ff976a;
  margin-left: 8rpx;
}

.confirm-btn {
  background: linear-gradient(135deg, #1989fa 0%, #3699ff 100%);
  color: #ffffff;
  padding: 28rpx 56rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(25, 137, 250, 0.35);
}

.confirm-btn:active {
  transform: scale(0.98);
}

.confirm-btn.disabled {
  background-color: #e0e0e0;
  color: #999999;
  box-shadow: none;
}

/* ========== 加载状态 ========== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #f5f6f7;
}

.loading-spinner {
  width: 72rpx;
  height: 72rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #1989fa;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 28rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #999999;
  font-size: 28rpx;
}

/* ========== 权限不足 ========== */
.permission-denied {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #f5f6f7;
}

.denied-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 80rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.denied-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}

.denied-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 16rpx;
}

.denied-desc {
  font-size: 28rpx;
  color: #999999;
}

/* pages/shop/detail/detail.wxss */
.container {
  padding-bottom: 140rpx;
}

/* 商品图片 */
.product-image-container {
  width: 100%;
  height: 600rpx;
  background-color: white;
}

.product-image {
  width: 100%;
  height: 100%;
}

/* 商品信息卡片 */
.product-info {
  margin-top: -40rpx;
  position: relative;
  z-index: 10;
}

.product-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.product-name {
  flex: 1;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-right: 20rpx;
}

.product-points {
  text-align: right;
}

.points-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #ff6b35;
  display: block;
}

.points-label {
  font-size: 24rpx;
  color: #ff6b35;
}

.product-meta {
  display: flex;
  flex-wrap: wrap;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.meta-item {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
}

.meta-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
}

.meta-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.product-status-tag {
  display: inline-flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 8rpx 20rpx;
  background-color: rgba(82, 196, 26, 0.1);
  border-radius: 8rpx;
  color: #52c41a;
  font-size: 26rpx;
}

.status-icon {
  margin-right: 6rpx;
  font-weight: bold;
}

.product-status-tag.out-of-stock {
  background-color: #f5f5f5;
  color: #999;
}

/* 商品描述 */
.product-description {
  margin-top: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 兑换说明 */
.exchange-rules {
  margin-top: 20rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.rule-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.rule-text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 用户积分 */
.user-points {
  margin-top: 20rpx;
}

.points-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.points-row:last-child {
  border-bottom: none;
}

.points-row.after-exchange {
  margin-top: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #f0f0f0;
  border-bottom: none;
}

.points-label {
  font-size: 28rpx;
  color: #666;
}

.points-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b35;
}

.after-label {
  font-size: 26rpx;
  color: #999;
}

.after-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #52c41a;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: white;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.history-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
}

.btn-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.history-btn text:last-child {
  font-size: 22rpx;
  color: #666;
}

.exchange-btn {
  flex: 1;
  background-color: #4A90D9;
  color: white;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.exchange-btn:active {
  background-color: #3a7bc8;
}

.exchange-btn-disabled {
  flex: 1;
  background-color: #f5f5f5;
  color: #999;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 32rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

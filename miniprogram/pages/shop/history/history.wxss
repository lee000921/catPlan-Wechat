/* 商城兑换历史页样式 - 蓝色系设计 */
.container {
  padding: 20rpx;
  padding-bottom: 180rpx;
  background: #f0f5ff;
}

/* 头部统计 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(24, 144, 255, 0.08);
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #262626;
}

.header-stats {
  display: flex;
  align-items: baseline;
}

.stats-label {
  font-size: 26rpx;
  color: #8c8c8c;
  margin-right: 8rpx;
}

.stats-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
}

.stats-unit {
  font-size: 26rpx;
  color: #8c8c8c;
  margin-left: 4rpx;
}

/* 兑换列表 */
.exchange-list {
  margin-top: 20rpx;
}

.loading-container,
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  background: #fff;
  border-radius: 24rpx;
}

.loading-text {
  color: #8c8c8c;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #262626;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #8c8c8c;
  margin-bottom: 40rpx;
}

.go-shop-btn {
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  color: white;
  padding: 20rpx 60rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.3);
}

/* 兑换项 */
.exchange-item {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(24, 144, 255, 0.08);
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-status {
  display: flex;
  align-items: center;
}

.status-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  font-weight: 500;
}

.status-tag.success {
  background: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.status-tag.pending {
  background: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

.status-tag.failed {
  background: rgba(255, 77, 79, 0.1);
  color: #ff4d4f;
}

.item-time {
  font-size: 24rpx;
  color: #8c8c8c;
}

.item-id {
  font-size: 22rpx;
  color: #8c8c8c;
}

/* 商品内容 */
.item-content {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background-color: #f5f7fa;
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #262626;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.item-meta {
  display: flex;
  align-items: center;
}

.item-points {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff6b35;
  margin-right: 20rpx;
}

.item-count {
  font-size: 26rpx;
  color: #8c8c8c;
}

/* 底部提示 */
.item-footer {
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.footer-tip {
  font-size: 24rpx;
  color: #52c41a;
}

/* 加载更多 */
.loading-more,
.no-more {
  text-align: center;
  padding: 30rpx 0;
  color: #8c8c8c;
  font-size: 26rpx;
}

/* 联系客服 */
.contact-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: white;
  box-shadow: 0 -2rpx 12rpx rgba(24, 144, 255, 0.08);
}

.contact-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f0f5ff, #e6f7ff);
  color: #1890ff;
  padding: 24rpx 0;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: 2rpx solid #1890ff;
}

.contact-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}
.contact-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f0f5ff, #e6f7ff);
  color: #1890ff;
  padding: 24rpx 0;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: 2rpx solid #1890ff;
}

.contact-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

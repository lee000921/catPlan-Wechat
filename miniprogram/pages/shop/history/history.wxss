/* pages/shop/history/history.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 160rpx;
}

/* 头部统计 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-stats {
  display: flex;
  align-items: baseline;
}

.stats-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 8rpx;
}

.stats-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #4A90D9;
}

.stats-unit {
  font-size: 26rpx;
  color: #999;
  margin-left: 4rpx;
}

/* 兑换列表 */
.exchange-list {
  margin-top: 20rpx;
}

.loading-container,
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.go-shop-btn {
  background-color: #4A90D9;
  color: white;
  padding: 20rpx 60rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}

/* 兑换项 */
.exchange-item {
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-status {
  display: flex;
  align-items: center;
}

.status-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.status-tag.success {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.status-tag.pending {
  background-color: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

.status-tag.failed {
  background-color: rgba(255, 77, 79, 0.1);
  color: #ff4d4f;
}

.item-time {
  font-size: 24rpx;
  color: #999;
}

.item-id {
  font-size: 22rpx;
  color: #999;
}

/* 商品内容 */
.item-content {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background-color: #f5f5f5;
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.item-meta {
  display: flex;
  align-items: center;
}

.item-points {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff6b35;
  margin-right: 20rpx;
}

.item-count {
  font-size: 26rpx;
  color: #999;
}

/* 底部提示 */
.item-footer {
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.footer-tip {
  font-size: 24rpx;
  color: #52c41a;
}

/* 加载更多 */
.loading-more,
.no-more {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 联系客服 */
.contact-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: white;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.contact-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  color: #333;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.contact-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

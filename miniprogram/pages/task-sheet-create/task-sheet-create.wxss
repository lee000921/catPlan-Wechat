.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 32rpx;
  padding-bottom: 200rpx;
}

.page-header {
  text-align: center;
  padding: 40rpx 0;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #262626;
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: #8c8c8c;
}

.form-section, .section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #262626;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 12rpx;
}

.input, .textarea, .picker {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #000000 !important;
  -webkit-text-fill-color: #000000 !important;
  background: #ffffff;
  box-sizing: border-box;
}

.textarea {
  min-height: 200rpx;
}

.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 模式选择器 */
.mode-selector {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.mode-item {
  flex: 1;
  padding: 20rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8c8c8c;
  transition: all 0.3s;
}

.mode-item.active {
  border-color: #1890ff;
  background: #e6f7ff;
  color: #1890ff;
  font-weight: 600;
}

/* 任务列表 */
.task-list-section {
  margin-top: 16rpx;
}

.task-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  transition: all 0.3s;
}

.task-item.selected {
  border-color: #1890ff;
  background: #e6f7ff;
}

.task-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.task-item.selected .task-checkbox {
  border-color: #1890ff;
  background: #1890ff;
}

.task-checkbox .checked {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.task-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.task-title {
  font-size: 28rpx;
  color: #262626;
}

.task-points {
  font-size: 24rpx;
  color: #faad14;
}

.empty-tasks {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-tasks text {
  font-size: 26rpx;
  color: #8c8c8c;
  margin-bottom: 24rpx;
}

.create-task-btn {
  background: #1890ff;
  color: #fff;
  border: none;
  border-radius: 32rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
}

/* 创建任务区域 */
.create-task-section {
  margin-top: 16rpx;
}

.add-task-btn {
  width: 100%;
  margin-top: 16rpx;
  padding: 20rpx;
  background: #52c41a;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
}

/* 预览区域 */
.preview-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.preview-list {
  margin-top: 16rpx;
}

.preview-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.preview-item:last-child {
  border-bottom: none;
}

.preview-item.new {
  background: #f6ffed;
  padding: 12rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
  border: 1rpx solid #b7eb8f;
}

.preview-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.preview-title {
  flex: 1;
  font-size: 26rpx;
  color: #262626;
}

.preview-points {
  font-size: 24rpx;
  color: #faad14;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.35);
}

.submit-btn[disabled] {
  background: #e0e0e0;
  box-shadow: none;
  color: #999;
}

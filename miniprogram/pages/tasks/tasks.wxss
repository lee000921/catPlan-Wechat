/* TEST FILE - 2026-03-09 01:00 - NEW VERSION */
/* 页面容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #ffffff 100%);
  padding-bottom: 120rpx;
}

/* 顶部装饰 */
.top-decoration {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  border-radius: 0 0 40rpx 40rpx;
  z-index: 0;
}

/* 用户卡片 */
.user-card {
  position: relative;
  z-index: 10;
  margin: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.user-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.user-avatar-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.user-info-text {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #262626;
}

.user-role {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-top: 4rpx;
}

.user-actions {
  display: flex;
  gap: 12rpx;
}

.role-switch-btn,
.logout-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  border: none;
}

.role-switch-btn {
  background: #e6f7ff;
  color: #1890ff;
}

.logout-btn {
  background: #fff1f0;
  color: #ff4d4f;
}

/* 统计卡片 */
.stats-card {
  position: relative;
  z-index: 10;
  margin: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #262626;
}

.stats-subtitle {
  font-size: 24rpx;
  color: #8c8c8c;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
}

.stat-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.stat-number {
  font-size: 36rpx;
  font-weight: 600;
  color: #1890ff;
}

.stat-label {
  font-size: 22rpx;
  color: #8c8c8c;
  margin-top: 4rpx;
}

/* 审批者视图切换 */
.view-switcher {
  position: relative;
  z-index: 10;
  margin: 0 24rpx 24rpx;
}

.switcher-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #8c8c8c;
  position: relative;
}

.tab-item.active {
  background: #e6f7ff;
  color: #1890ff;
  font-weight: 600;
}

.tab-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  min-width: 24rpx;
  text-align: center;
}

/* 任务列表 */
.task-scroll {
  height: calc(100vh - 400rpx);
  padding: 0 24rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.task-card {
  width: 100%;
  max-width: 700rpx;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.task-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
}

.task-card.approval-view {
  border-left: 6rpx solid #1890ff;
}

/* 状态指示条 */
.status-indicator {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
}

.status-indicator.status-pending {
  background: linear-gradient(90deg, #faad14, #ffc53d);
}

.status-indicator.status-approved {
  background: linear-gradient(90deg, #1890ff, #40a9ff);
}

.status-indicator.status-rejected {
  background: linear-gradient(90deg, #ff4d4f, #ff7875);
}

.status-indicator.status-completed {
  background: linear-gradient(90deg, #52c41a, #73d13d);
}

/* 任务头部 */
.task-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.task-title-section {
  flex: 1;
}

.task-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #262626;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.task-meta {
  display: flex;
  gap: 12rpx;
}

.task-date,
.task-id {
  font-size: 22rpx;
  color: #8c8c8c;
}

.task-status-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: #f5f7fa;
  color: #8c8c8c;
}

.status-icon {
  font-size: 24rpx;
}

/* 任务描述 */
.task-desc {
  margin-bottom: 16rpx;
}

.desc-text {
  display: block;
  font-size: 26rpx;
  color: #595959;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 审批信息 */
.approval-info {
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.approval-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.approval-date {
  font-size: 22rpx;
  color: #8c8c8c;
}

.approval-status-badge {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.approval-status-badge.approved {
  background: #e6f7ff;
  color: #1890ff;
}

.approval-status-badge.rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

.approval-comment {
  font-size: 24rpx;
  color: #595959;
  line-height: 1.4;
}

/* 任务底部 */
.task-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.task-points {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.points-icon {
  font-size: 24rpx;
}

.points-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #faad14;
}

.points-label {
  font-size: 24rpx;
  color: #8c8c8c;
}

.task-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #1890ff;
}

.action-arrow {
  font-size: 28rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #8c8c8c;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 8rpx;
}

.empty-subtitle {
  font-size: 26rpx;
  color: #8c8c8c;
}

.safe-bottom {
  height: 40rpx;
}

/* FAB 悬浮按钮 */
.fab-container {
  position: fixed;
  bottom: 80rpx;
  right: 32rpx;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.fab-main {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  box-shadow: 0 8rpx 32rpx rgba(24, 144, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.fab-icon {
  font-size: 56rpx;
}

/* 扩展按钮组 - 始终显示 */
.fab-extended {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  align-items: flex-end;
}

.fab-ext-btn {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  border: none;
  gap: 12rpx;
  white-space: nowrap;
}

.fab-ext-btn:active {
  background: #f0f0f0;
  transform: scale(0.95);
}

.ext-icon {
  font-size: 32rpx;
}

.ext-text {
  font-size: 26rpx;
  color: #262626;
  font-weight: 500;
}

.fab-ripple {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(24, 144, 255, 0.3);
  transform: scale(0);
  z-index: -1;
}

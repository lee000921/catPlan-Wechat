/* 任务列表页样式 - 蓝色系设计 */

/* 页面容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  position: relative;
  overflow: hidden;
}

/* 顶部装饰 */
.top-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.05) 100%);
  border-radius: 0 0 50% 50%;
}

/* 用户卡片 */
.user-card {
  margin: 30rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 0;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
  position: relative;
  z-index: 2;
  overflow: hidden;
}

.user-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx;
}

.user-avatar-section {
  display: flex;
  align-items: center;
  flex: 1;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 6rpx solid rgba(24, 144, 255, 0.15);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

.user-info-text {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #262626;
  margin-bottom: 8rpx;
}

.user-role {
  display: block;
  font-size: 28rpx;
  color: #1890ff;
  font-weight: 500;
}

.user-actions {
  display: flex;
  gap: 16rpx;
}

.role-switch-btn, .logout-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: transparent;
  border: none;
  padding: 16rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.role-switch-btn {
  background: linear-gradient(135deg, #f0f5ff, #fff);
}

.logout-btn {
  background: linear-gradient(135deg, #fff5f5, #fff);
}

.switch-icon, .logout-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.switch-text, .logout-text {
  font-size: 24rpx;
  color: #595959;
  font-weight: 500;
}

/* 统计卡片 */
.stats-card {
  margin: 30rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
  position: relative;
  z-index: 2;
}

.stats-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #1890ff, #40a9ff);
  border-radius: 32rpx 32rpx 0 0;
}

.stats-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.stats-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #262626;
  margin-bottom: 8rpx;
}

.stats-subtitle {
  display: block;
  font-size: 26rpx;
  color: #8c8c8c;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30rpx;
}

.stat-box {
  text-align: center;
  padding: 30rpx 20rpx;
  background: linear-gradient(135deg, #f0f5ff 0%, #fff 100%);
  border-radius: 24rpx;
  border: 2rpx solid rgba(24, 144, 255, 0.1);
  transition: all 0.3s ease;
}

.stat-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.stat-number {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  background: linear-gradient(90deg, #1890ff, #40a9ff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 26rpx;
  color: #595959;
  font-weight: 500;
}

/* 视图切换器 */
.view-switcher {
  margin: 30rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 8rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
  position: relative;
  z-index: 2;
  overflow: hidden;
}

.view-switcher::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #1890ff, #40a9ff);
}

.switcher-tabs {
  display: flex;
  gap: 8rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  border-radius: 24rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.tab-item.active {
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  color: #fff;
  transform: scale(1.02);
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.3);
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 600;
}

.tab-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: linear-gradient(135deg, #ff4d4f, #ff7875);
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

/* 任务滚动区域 */
.task-scroll {
  flex: 1;
  padding: 0 30rpx 200rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid rgba(24, 144, 255, 0.1);
  border-top: 8rpx solid #1890ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  padding: 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.8;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.empty-subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  text-align: center;
}

/* 任务列表 */
.task-list {
  padding-top: 30rpx;
}

/* 任务卡片 */
.task-card {
  background: #fff;
  border-radius: 32rpx;
  margin-bottom: 30rpx;
  padding: 0;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.task-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 30rpx 80rpx rgba(0,0,0,0.2);
}

.task-card.approval-view {
  border-left: 8rpx solid #1890ff;
}

/* 状态指示条 */
.status-indicator {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
}

.status-indicator.status-pending {
  background: linear-gradient(90deg, #faad14, #ffc53d);
}

.status-indicator.status-approved {
  background: linear-gradient(90deg, #1890ff, #40a9ff);
}

.status-indicator.status-rejected {
  background: linear-gradient(90deg, #ff4d4f, #ff7875);
}

.status-indicator.status-completed {
  background: linear-gradient(90deg, #52c41a, #73d13d);
}

/* 任务头部 */
.task-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 40rpx 40rpx 20rpx;
}

.task-title-section {
  flex: 1;
  margin-right: 20rpx;
}

.task-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #262626;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.task-meta {
  display: flex;
  gap: 16rpx;
}

.task-date {
  font-size: 24rpx;
  color: #8c8c8c;
  background: #f5f5f5;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
}

.task-id {
  font-size: 24rpx;
  color: #1890ff;
  background: #f0f5ff;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

/* 任务状态徽章 */
.task-status-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  min-width: 120rpx;
}

.task-status-badge.status-pending {
  background: linear-gradient(135deg, #fffbe6, #fff1b8);
}

.task-status-badge.status-approved {
  background: linear-gradient(135deg, #e6f7ff, #bae7ff);
}

.task-status-badge.status-rejected {
  background: linear-gradient(135deg, #fff1f0, #ffccc7);
}

.task-status-badge.status-completed {
  background: linear-gradient(135deg, #f6ffed, #d9f7be);
}

.status-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.status-text {
  font-size: 24rpx;
  font-weight: 600;
}

.status-pending .status-text { color: #faad14; }
.status-approved .status-text { color: #1890ff; }
.status-rejected .status-text { color: #ff4d4f; }
.status-completed .status-text { color: #52c41a; }

/* 任务描述 */
.task-desc {
  padding: 0 40rpx 20rpx;
}

.desc-text {
  font-size: 30rpx;
  color: #595959;
  line-height: 1.8;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

/* 任务底部 */
.task-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 40rpx 40rpx;
  border-top: 1rpx solid #f0f0f0;
}

.task-points {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.points-icon {
  font-size: 32rpx;
}

.points-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b35;
}

.points-label {
  font-size: 24rpx;
  color: #8c8c8c;
}

.task-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-text {
  font-size: 26rpx;
  color: #8c8c8c;
}

.action-arrow {
  font-size: 28rpx;
  color: #1890ff;
  font-weight: bold;
}

/* 审批信息 */
.approval-info {
  padding: 20rpx 40rpx;
  background: linear-gradient(135deg, rgba(24, 144, 255, 0.05), rgba(64, 169, 255, 0.05));
  border-top: 1rpx solid #f0f0f0;
}

.approval-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.approval-date {
  font-size: 24rpx;
  color: #1890ff;
  font-weight: 500;
}

.approval-status-badge {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 600;
}

.approval-status-badge.approved {
  background: linear-gradient(135deg, #e6f7ff, #bae7ff);
  color: #1890ff;
}

.approval-status-badge.rejected {
  background: linear-gradient(135deg, #fff1f0, #ffccc7);
  color: #ff4d4f;
}

.approval-comment {
  font-size: 28rpx;
  color: #595959;
  line-height: 1.6;
  background: #fff;
  padding: 16rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid #1890ff;
}

/* 安全区域 */
.safe-bottom {
  height: 100rpx;
}

/* 悬浮按钮 */
.fab-container {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  z-index: 9999;
  width: 120rpx;
  height: 120rpx;
}

.fab-main {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 20rpx 60rpx rgba(24, 144, 255, 0.4);
  transition: all 0.3s ease;
  border: none;
  padding: 0;
  margin: 0;
}

.fab-main:active {
  transform: scale(0.95);
}

.fab-main::after {
  border: none;
}

.fab-icon {
  font-size: 48rpx;
  color: #fff;
  animation: float 3s ease-in-out infinite;
  position: relative;
  z-index: 1;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

.fab-ripple {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
  animation: ripple-pulse 2s ease-in-out infinite;
  pointer-events: none;
}

@keyframes ripple-pulse {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.1); opacity: 0.5; }
  100% { transform: scale(1); opacity: 1; }
}

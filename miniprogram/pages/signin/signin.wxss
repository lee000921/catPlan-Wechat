/* 签到页样式 - 蓝色系设计 */

.container { 
  padding: 20rpx; 
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  min-height: 100vh;
}

/* 用户信息卡片 */
.user-card {
  width: 710rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 3rpx solid #1890ff;
}

.user-details {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 4rpx;
}

.user-level {
  font-size: 24rpx;
  color: #1890ff;
  font-weight: 500;
}

.streak-badge {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
}

.streak-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.streak-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

/* 主卡片 */
.main-card {
  width: 710rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
  position: relative;
  overflow: hidden;
}

.main-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #1890ff, #40a9ff);
}

/* 日历头部 */
.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.month-nav {
  display: flex;
  align-items: center;
}

.nav-btn {
  background: #f0f5ff;
  border: none;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.1);
  transition: all 0.3s ease;
}

.nav-btn:active {
  transform: scale(0.95);
  background: #e6f7ff;
}

.nav-icon {
  font-size: 32rpx;
  color: #1890ff;
  font-weight: 600;
}

.month-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #262626;
  margin: 0 24rpx;
}

.signin-btn {
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  border: none;
  border-radius: 32rpx;
  padding: 0;
  min-width: 160rpx;
  height: 80rpx;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.35);
  transition: all 0.3s ease;
}

.signin-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(24, 144, 255, 0.35);
}

.signin-btn.signed {
  background: linear-gradient(135deg, #95afc0, #535c68);
  box-shadow: 0 4rpx 16rpx rgba(149, 175, 192, 0.3);
}

.signin-btn[disabled] {
  background: #dfe6e9;
  box-shadow: none;
}

.signin-btn::after {
  border: none;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 24rpx;
}

.btn-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

/* 日历容器 */
.calendar-container {
  margin-bottom: 32rpx;
}

.weekdays {
  display: flex;
  margin-bottom: 16rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  color: #8c8c8c;
  font-size: 24rpx;
  font-weight: 600;
  padding: 12rpx 0;
}

.days-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-cell {
  width: calc(100% / 7);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  position: relative;
  transition: all 0.3s ease;
}

.day-cell.today {
  background: #f0f5ff;
  border-radius: 16rpx;
}

.day-cell.signed {
  background: linear-gradient(135deg, rgba(24, 144, 255, 0.1), rgba(64, 169, 255, 0.1));
  border-radius: 16rpx;
}

.day-number {
  font-size: 28rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 4rpx;
}

.day-cell.signed .day-number {
  color: #1890ff;
}

.day-indicator {
  width: 32rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.3);
}

.indicator-icon {
  font-size: 18rpx;
  color: #fff;
  font-weight: 600;
}

/* 统计信息 */
.stats-container {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.stat-card {
  flex: 1;
  background: #f5f7fa;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
}

.stat-card:active {
  transform: scale(0.98);
}

.stat-card.highlight {
  background: linear-gradient(135deg, rgba(24, 144, 255, 0.1), rgba(64, 169, 255, 0.1));
  border: 2rpx solid rgba(24, 144, 255, 0.2);
}

.stat-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.stat-info {
  flex: 1;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #262626;
  margin-bottom: 4rpx;
}

.stat-card.highlight .stat-value {
  color: #1890ff;
}

.stat-label {
  font-size: 22rpx;
  color: #8c8c8c;
}

/* 奖励卡片 */
.reward-card {
  width: 710rpx;
  background: linear-gradient(135deg, rgba(255, 193, 7, 0.1), rgba(255, 152, 0, 0.1));
  border: 2rpx solid rgba(255, 193, 7, 0.3);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 193, 7, 0.15);
}

.reward-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.reward-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.reward-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ff8c00;
}

.reward-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.reward-text {
  font-size: 26rpx;
  color: #595959;
  font-weight: 500;
}

.reward-bonus {
  font-size: 24rpx;
  color: #ff8c00;
  font-weight: 600;
}

/* 积分动画样式 */
.points-animation {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.animation-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}

.points-popup {
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx;
  text-align: center;
  box-shadow: 0 24rpx 72rpx rgba(0, 0, 0, 0.3);
  animation: popupScale 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  position: relative;
  z-index: 1;
}

@keyframes popupScale {
  0% { transform: scale(0.3); opacity: 0; }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); opacity: 1; }
}

.success-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  animation: successBounce 0.8s ease-out;
}

@keyframes successBounce {
  0%, 100% { transform: scale(1); }
  25% { transform: scale(1.2) rotate(-5deg); }
  75% { transform: scale(1.1) rotate(5deg); }
}

.points-text {
  font-size: 64rpx;
  font-weight: 800;
  color: #ff6b35;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: pointsBounce 0.6s ease-out;
}

@keyframes pointsBounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}

.points-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 16rpx;
}

.points-detail {
  font-size: 24rpx;
  color: #8c8c8c;
  line-height: 1.5;
  background: #f5f7fa;
  padding: 16rpx;
  border-radius: 16rpx;
  margin-top: 16rpx;
}

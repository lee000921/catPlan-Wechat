<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatarUrl}}" wx:if="{{userInfo}}" />
      <view class="user-details">
        <view class="nickname">{{userInfo.nickName}}</view>
        <view class="user-level">Lv.{{Math.floor(signedCount/7)+1}} 签到达人</view>
      </view>
    </view>
    <view class="streak-badge">
      <view class="streak-icon">🔥</view>
      <view class="streak-text">{{consecutiveCount}}天连续</view>
    </view>
  </view>

  <!-- 签到主卡片 -->
  <view class="main-card">
    <!-- 月份导航和签到按钮 -->
    <view class="calendar-header">
      <view class="month-nav">
        <button bindtap="onPrevMonth" class="nav-btn">
          <text class="nav-icon">‹</text>
        </button>
        <view class="month-title">{{year}}年{{month}}月</view>
        <button bindtap="onNextMonth" class="nav-btn">
          <text class="nav-icon">›</text>
        </button>
      </view>
      <button class="signin-btn {{signedToday ? 'signed' : ''}}" bindtap="onCheckin" disabled="{{signedToday || checking}}">
        <view class="btn-content">
          <text class="btn-icon">{{signedToday ? '✓' : '🎯'}}</text>
          <text class="btn-text">{{checking ? '签到中...' : (signedToday ? '已签到' : '签到')}}</text>
        </view>
      </button>
    </view>

    <!-- 日历视图 -->
    <view class="calendar-container">
      <view class="weekdays">
        <view wx:for="{{weekdays}}" wx:key="index" class="weekday">{{item}}</view>
      </view>
      <view class="days-grid">
        <view wx:for="{{cells}}" wx:key="index" class="day-cell {{item.signed ? 'signed' : ''}} {{item.isToday ? 'today' : ''}}" data-day="{{item.date}}" bindtap="onDayTap">
          <view class="day-number">{{item.display}}</view>
          <view class="day-indicator" wx:if="{{item.signed}}">
            <text class="indicator-icon">✓</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 统计信息 -->
    <view class="stats-container">
      <view class="stat-card">
        <view class="stat-icon">📅</view>
        <view class="stat-info">
          <view class="stat-value">{{signedCount}}</view>
          <view class="stat-label">累计签到</view>
        </view>
      </view>
      <view class="stat-card">
        <view class="stat-icon">⚡</view>
        <view class="stat-info">
          <view class="stat-value">{{consecutiveCount}}</view>
          <view class="stat-label">连续天数</view>
        </view>
      </view>
      <view class="stat-card highlight">
        <view class="stat-icon">💎</view>
        <view class="stat-info">
          <view class="stat-value">{{stats.totalPoints || 0}}</view>
          <view class="stat-label">总积分</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 签到奖励提示卡片 -->
  <view class="reward-card" wx:if="{{!signedToday}}">
    <view class="reward-header">
      <text class="reward-icon">🎁</text>
      <text class="reward-title">签到奖励</text>
    </view>
    <view class="reward-content">
      <text class="reward-text">基础积分 +10</text>
      <text class="reward-bonus" wx:if="{{consecutiveCount > 0}}">连续{{consecutiveCount}}天额外 +{{consecutiveCount * 2}}</text>
    </view>
  </view>
  
  <!-- 积分获取动画 -->
  <view class="points-animation" wx:if="{{showPointsAnimation}}">
    <view class="animation-backdrop"></view>
    <view class="points-popup">
      <view class="success-icon">🎉</view>
      <view class="points-text">+{{animationPoints}} 积分</view>
      <view class="points-label">签到成功！</view>
      <view class="points-detail" wx:if="{{consecutiveCount > 1}}">
        连续{{consecutiveCount}}天额外奖励 +{{consecutiveCount * 2}}
      </view>
    </view>
  </view>
</view>

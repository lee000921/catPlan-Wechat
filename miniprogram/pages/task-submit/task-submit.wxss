/* 页面容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #ffffff 100%);
  padding-bottom: 240rpx;
}

/* 顶部背景 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 360rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 0 48rpx 48rpx;
  overflow: hidden;
}

.header-pattern {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.header-pattern::before {
  content: '';
  position: absolute;
  top: 80rpx;
  left: -100rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

/* 页面标题 */
.page-header {
  display: flex;
  align-items: center;
  padding: 60rpx 32rpx 40rpx;
  position: relative;
  z-index: 2;
}

.header-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  backdrop-filter: blur(10px);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.header-icon {
  font-size: 48rpx;
}

.header-content {
  flex: 1;
}

.page-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 10rpx;
}

/* 表单区域 */
.form-wrapper {
  padding: 0 24rpx;
  position: relative;
  z-index: 2;
  margin-top: -40rpx;
}

/* 卡片通用样式 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #262626;
}

.required-mark {
  font-size: 30rpx;
  color: #ff4d4f;
  margin-left: 4rpx;
  font-weight: 700;
}

/* 任务类型选择器 */
.type-selector {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-top: 8rpx;
}

.type-item {
  padding: 32rpx 20rpx;
  border: 3rpx solid #e8e8e8;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  background: linear-gradient(180deg, #fafafa 0%, #f5f5f5 100%);
}

.type-item.active {
  border-color: #667eea;
  background: linear-gradient(180deg, #f0f4ff 0%, #e6eeff 100%);
  transform: translateY(-6rpx);
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.25);
}

.type-icon {
  font-size: 56rpx;
}

.type-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #262626;
}

.type-desc {
  font-size: 24rpx;
  color: #8c8c8c;
}

/* 输入区域 */
.input-area {
  position: relative;
}

.form-input {
  width: 100%;
  padding: 28rpx 24rpx;
  padding-right: 140rpx;
  border: 3rpx solid #e8e8e8;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #000000 !important;
  -webkit-text-fill-color: #000000 !important;
  font-weight: 500;
  box-sizing: border-box;
  background: #fafafa;
  transition: all 0.3s;
}

.form-input:focus {
  border-color: #667eea;
  background: #ffffff;
  box-shadow: 0 0 0 6rpx rgba(102, 126, 234, 0.12);
}

.input-counter {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: #8c8c8c;
  background: #fff;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* 文本域 */
.textarea-area {
  position: relative;
}

.form-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx;
  padding-bottom: 60rpx;
  border: 3rpx solid #e8e8e8;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #000000 !important;
  -webkit-text-fill-color: #000000 !important;
  font-weight: 500;
  line-height: 1.8;
  box-sizing: border-box;
  background: #fafafa;
  resize: none;
  transition: all 0.3s;
}

.form-textarea:focus {
  border-color: #667eea;
  background: #ffffff;
  box-shadow: 0 0 0 6rpx rgba(102, 126, 234, 0.12);
}

.textarea-counter {
  position: absolute;
  right: 24rpx;
  bottom: 20rpx;
  font-size: 24rpx;
  color: #8c8c8c;
}

/* 积分输入 */
.points-area {
  background: linear-gradient(135deg, #f0f5ff 0%, #ffffff 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 3rpx solid #d6e4ff;
}

.points-input-box {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.points-prefix {
  font-size: 40rpx;
  font-weight: 700;
  color: #667eea;
  margin-right: 12rpx;
}

.points-input {
  flex: 1;
  font-size: 52rpx;
  font-weight: 700;
  color: #667eea;
  text-align: center;
  border: none;
  background: transparent;
}

.points-suffix {
  font-size: 28rpx;
  color: #8c8c8c;
  margin-left: 12rpx;
}

.points-tips {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 20rpx;
  background: rgba(102, 126, 234, 0.06);
  border-radius: 12rpx;
}

.tips-icon {
  font-size: 28rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #595959;
  line-height: 1.5;
}

/* 周期配置 */
.form-group {
  margin-bottom: 28rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #595959;
  margin-bottom: 16rpx;
}

.radio-group {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.radio-item {
  padding: 20rpx;
  border: 3rpx solid #e8e8e8;
  border-radius: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8c8c8c;
  transition: all 0.3s;
  background: #fafafa;
}

.radio-item.active {
  border-color: #667eea;
  background: linear-gradient(180deg, #f0f4ff 0%, #e6eeff 100%);
  color: #667eea;
  font-weight: 700;
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.2);
}

.weekday-selector {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 12rpx;
}

.weekday-item {
  padding: 20rpx 0;
  border: 3rpx solid #e8e8e8;
  border-radius: 14rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8c8c8c;
  transition: all 0.3s;
  background: #fafafa;
}

.weekday-item.selected {
  border-color: #667eea;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: 700;
  transform: scale(1.05);
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
}

.picker {
  padding: 24rpx;
  border: 3rpx solid #e8e8e8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #262626;
  background: #ffffff;
}

/* 任务预览卡片 */
.preview-card {
  background: linear-gradient(135deg, #fffbe6 0%, #ffffff 100%);
  border-radius: 20rpx;
  overflow: hidden;
  border: 3rpx solid #ffe58f;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(250, 173, 20, 0.15);
}

.preview-header {
  padding: 24rpx 32rpx;
  background: linear-gradient(90deg, rgba(250, 173, 20, 0.1) 0%, rgba(250, 173, 20, 0.05) 100%);
  border-bottom: 2rpx solid rgba(250, 173, 20, 0.15);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.preview-badge {
  font-size: 24rpx;
  color: #d48806;
  background: rgba(250, 173, 20, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.preview-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #262626;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-body {
  padding: 28rpx 32rpx;
}

.preview-desc {
  display: block;
  font-size: 28rpx;
  color: #595959;
  line-height: 1.8;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.preview-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.preview-points {
  font-size: 36rpx;
  font-weight: 700;
  color: #667eea;
}

.preview-periodic {
  font-size: 26rpx;
  color: #667eea;
  background: #f0f4ff;
  padding: 8rpx 20rpx;
  border-radius: 10rpx;
  font-weight: 600;
}

/* 底部提交区域 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.submit-tips {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.submit-tips .tips-icon {
  font-size: 26rpx;
}

.submit-tips .tips-text {
  font-size: 26rpx;
  color: #8c8c8c;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 108rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border: none;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.submit-btn[disabled] {
  background: linear-gradient(135deg, #d9d9d9 0%, #bfbfbf 100%);
  box-shadow: none;
  color: #8c8c8c;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 34rpx;
  font-weight: 700;
}

.btn-loading {
  font-size: 30rpx;
}

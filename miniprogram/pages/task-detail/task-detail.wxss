/**
 * 任务详情页样式 - UI 优化版
 * 设计规范：
 * - 主色调：#1890ff
 * - 卡片圆角：16rpx
 * - 卡片阴影：0 4rpx 20rpx rgba(0,0,0,0.08)
 * - 间距：24rpx (卡片内), 32rpx (区块间)
 * - 字号：标题 36rpx, 正文 28rpx, 辅助 24rpx
 * - 行高：1.6
 * Co-authored-by: 丹青 ✏️
 */

/* 页面容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f5ff 0%, #ffffff 100%);
  padding-bottom: 40rpx;
}

/* 加载状态 */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e6e6e6;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 24rpx;
}

/* 任务内容区域 */
.task-content {
  padding: 32rpx 24rpx;
}

/* 卡片通用样式 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

/* 卡片头部 */
.card-header {
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

/* ========== 标题卡片 ========== */
.title-card {
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.25);
}

.title-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.task-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 状态徽章 */
.status-badge {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
}

.status-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.status-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #ffffff;
}

/* 不同状态的徽章样式 */
.status-pending .status-badge {
  background: rgba(250, 173, 20, 0.95);
}

.status-approved .status-badge {
  background: rgba(82, 196, 26, 0.95);
}

.status-rejected .status-badge {
  background: rgba(255, 77, 79, 0.95);
}

.status-completed .status-badge {
  background: rgba(114, 46, 209, 0.95);
}

/* ========== 描述卡片 ========== */
.desc-content {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  word-wrap: break-word;
  word-break: break-all;
}

/* ========== 信息卡片 ========== */
.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.info-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.info-icon {
  font-size: 32rpx;
  line-height: 1;
}

.info-content {
  flex: 1;
  min-width: 0;
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.info-value {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-value.highlight {
  color: #1890ff;
  font-weight: 600;
}

/* ========== 审批记录卡片 ========== */
.timeline {
  position: relative;
}

.timeline-item {
  display: flex;
  gap: 24rpx;
  position: relative;
  padding-bottom: 32rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-item:last-child .timeline-line::after {
  display: none;
}

.timeline-line {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 32rpx;
  flex-shrink: 0;
}

.timeline-line::after {
  content: '';
  position: absolute;
  left: 15rpx;
  top: 40rpx;
  width: 2rpx;
  height: calc(100% - 40rpx);
  background: #e8e8e8;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  flex-shrink: 0;
  z-index: 1;
}

.timeline-dot.approved {
  background: #52c41a;
  box-shadow: 0 0 0 8rpx rgba(82, 196, 26, 0.15);
}

.timeline-dot.rejected {
  background: #ff4d4f;
  box-shadow: 0 0 0 8rpx rgba(255, 77, 79, 0.15);
}

.timeline-content {
  flex: 1;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx;
}

.approval-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.approver-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.approval-status {
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.approval-status.approved {
  background: #f6ffed;
  color: #52c41a;
}

.approval-status.rejected {
  background: #fff2f0;
  color: #ff4d4f;
}

.approval-comment {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
  padding: 12rpx;
  background: #ffffff;
  border-radius: 8rpx;
}

.approval-date {
  font-size: 24rpx;
  color: #999;
}

/* ========== 审批表单卡片 ========== */
.form-section {
  margin-bottom: 24rpx;
}

.form-section:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.label-hint {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

/* 状态选择按钮 */
.status-options {
  display: flex;
  gap: 24rpx;
}

.status-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  background: #fafafa;
  border: 2rpx solid #e8e8e8;
  transition: all 0.3s;
}

.status-option.selected {
  transform: scale(1.02);
}

.status-option.selected.approved {
  background: #f6ffed;
  border-color: #52c41a;
  box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.15);
}

.status-option.selected.rejected {
  background: #fff2f0;
  border-color: #ff4d4f;
  box-shadow: 0 4rpx 12rpx rgba(255, 77, 79, 0.15);
}

.option-icon {
  font-size: 32rpx;
  font-weight: 600;
}

.status-option.selected.approved .option-icon {
  color: #52c41a;
}

.status-option.selected.rejected .option-icon {
  color: #ff4d4f;
}

.option-text {
  font-size: 28rpx;
  color: #666;
}

.status-option.selected .option-text {
  font-weight: 600;
}

.status-option.selected.approved .option-text {
  color: #52c41a;
}

.status-option.selected.rejected .option-text {
  color: #ff4d4f;
}

/* 文本输入 */
.textarea-wrapper {
  position: relative;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
  background: #fafafa;
  resize: none;
}

.form-textarea:focus {
  border-color: #1890ff;
  background: #ffffff;
}

.textarea-counter {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  font-size: 24rpx;
  color: #999;
}

/* 表单按钮 */
.form-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.btn-cancel, .btn-submit {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.3s;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-cancel:active {
  background: #e8e8e8;
}

.btn-submit.approve {
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.25);
}

.btn-submit.reject {
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(255, 77, 79, 0.25);
}

.btn-submit:active {
  transform: scale(0.98);
}

.btn-submit[disabled] {
  opacity: 0.6;
}

/* ========== 完成任务卡片 ========== */
.complete-card {
  background: linear-gradient(135deg, #f6ffed 0%, #ffffff 100%);
  border: 2rpx solid #b7eb8f;
}

.complete-info {
  text-align: center;
  margin-bottom: 24rpx;
}

.complete-hint {
  display: block;
  font-size: 28rpx;
  color: #52c41a;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.complete-points {
  font-size: 24rpx;
  color: #999;
}

.btn-complete {
  width: 100%;
  height: 88rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.25);
}

.btn-complete:active {
  transform: scale(0.98);
}

.btn-complete[disabled] {
  opacity: 0.6;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 500;
}

/* ========== 空状态 ========== */
.empty-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* 审批表单样式 */
.approval-form {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.approval-form .section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #262626;
  margin-bottom: 24rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #595959;
}

.radio-group {
  display: flex;
  gap: 32rpx;
}

.radio-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  border: 3rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #595959;
  transition: all 0.3s;
  cursor: pointer;
}

.radio-label.checked {
  border-color: #1890ff;
  background: #e6f7ff;
  color: #1890ff;
  font-weight: 600;
}

.radio-dot {
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid #d9d9d9;
  border-radius: 50%;
  transition: all 0.3s;
}

.radio-dot.active {
  border-color: #1890ff;
  background: #1890ff;
  box-shadow: 0 0 0 4rpx rgba(24, 144, 255, 0.2);
}

.textarea-wrapper {
  position: relative;
}

.approval-comment {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  padding-bottom: 50rpx;
  border: 3rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #262626;
  line-height: 1.6;
  box-sizing: border-box;
  background: #fafafa;
  resize: none;
}

.approval-comment:focus {
  border-color: #1890ff;
  background: #fff;
}

.textarea-counter {
  position: absolute;
  right: 20rpx;
  bottom: 16rpx;
  font-size: 24rpx;
  color: #8c8c8c;
}

.approval-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.cancel-btn,
.approval-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn {
  background: #f5f5f5;
  color: #595959;
}

.approval-btn {
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.3);
}

.approval-btn[disabled] {
  background: #d9d9d9;
  box-shadow: none;
}

.complete-section {
  margin-top: 24rpx;
}

.complete-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  color: #fff;
  border: none;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.3);
}

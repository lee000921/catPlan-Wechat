<view class="container">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 任务单详情 -->
  <view wx:if="{{!loading && taskSheet}}" class="task-sheet-detail">
    <!-- 头部卡片 -->
    <view class="header-card">
      <view class="title-row">
        <text class="sheet-title">{{taskSheet.title}}</text>
        <view class="status-tag status-{{taskSheet.status}}">
          {{statusMap[taskSheet.status]}}
        </view>
      </view>
      <view class="date-row">
        <text class="date-icon">📅</text>
        <text class="date-text">{{taskSheet.date}}</text>
      </view>
    </view>

    <!-- 进度卡片 -->
    <view class="progress-card">
      <view class="progress-header">
        <text class="progress-label">完成进度</text>
        <text class="progress-percent">{{taskSheet.progress}}%</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{taskSheet.progress}}%"></view>
      </view>
      <view class="progress-stats">
        <view class="stat-item">
          <text class="stat-value completed">{{taskSheet.completed_tasks}}</text>
          <text class="stat-label">已完成</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value total">{{taskSheet.total_tasks}}</text>
          <text class="stat-label">总任务</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value remaining">{{taskSheet.total_tasks - taskSheet.completed_tasks}}</text>
          <text class="stat-label">待完成</text>
        </view>
      </view>
    </view>

    <!-- 任务列表 -->
    <view class="tasks-section">
      <view class="section-header">
        <text class="section-title">任务清单</text>
        <text class="section-count">{{taskSheet.tasks ? taskSheet.tasks.length : 0}} 个任务</text>
      </view>

      <view wx:if="{{taskSheet.tasks && taskSheet.tasks.length > 0}}" class="task-list">
        <view wx:for="{{taskSheet.tasks}}" wx:key="id" class="task-item {{item.completed ? 'completed' : ''}}">
          <view class="task-checkbox">
            <view wx:if="{{item.completed}}" class="checkbox-checked">✓</view>
            <view wx:else class="checkbox-empty"></view>
          </view>
          <view class="task-content">
            <text class="task-title">{{item.title}}</text>
            <view class="task-meta">
              <text class="task-points">🎯 {{item.points}} 碎片</text>
              <text wx:if="{{item.status}}" class="task-status status-{{item.status}}">
                {{item.status === 'completed' ? '已完成' : item.status === 'approved' ? '已通过' : item.status === 'rejected' ? '已拒绝' : '待审批'}}
              </text>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{!taskSheet.tasks || taskSheet.tasks.length === 0}}" class="empty-tasks">
        <text class="empty-icon">📝</text>
        <text class="empty-text">暂无任务</text>
        <button class="add-task-btn" bindtap="goToAddTask">添加任务</button>
      </view>
    </view>

    <!-- 底部操作栏 -->
    <view class="action-bar">
      <button class="action-btn secondary" bindtap="syncProgress">
        <text class="btn-icon">🔄</text>
        <text>同步进度</text>
      </button>
      <button class="action-btn primary" bindtap="addTask">
        <text class="btn-icon">➕</text>
        <text>添加任务</text>
      </button>
    </view>
  </view>

  <!-- 无数据 -->
  <view wx:if="{{!loading && !taskSheet}}" class="empty-container">
    <text class="empty-icon">📋</text>
    <text class="empty-text">任务单不存在</text>
    <button class="back-btn" bindtap="goBack">返回</button>
  </view>
</view>

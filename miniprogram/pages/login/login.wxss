/* 登录页样式 - 蓝色系现代化设计 */

.container {
  padding: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
}

.card {
  width: 680rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(24, 144, 255, 0.25);
  padding: 60rpx 40rpx;
  align-items: center;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, #1890ff, #40a9ff);
}

.title {
  font-size: 44rpx;
  color: #262626;
  margin-bottom: 48rpx;
  font-weight: 700;
  position: relative;
  letter-spacing: 2rpx;
}

.title::after {
  content: '';
  position: absolute;
  bottom: -12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #1890ff, #40a9ff);
  border-radius: 3rpx;
}

.role-section {
  width: 100%;
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 28rpx;
  color: #595959;
  margin-bottom: 32rpx;
  font-weight: 600;
  text-align: left;
}

.role-group {
  width: 100%;
}

.role-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #f0f5ff, #ffffff);
  border: 2rpx solid #e6f7ff;
  transition: all 0.3s ease;
}

.role-item:active {
  background: #e6f7ff;
  transform: translateY(-2rpx);
}

.role-item:last-child {
  margin-bottom: 0;
}

.role-item radio {
  margin-right: 20rpx;
  margin-top: 6rpx;
  transform: scale(1.1);
}

.role-info {
  flex: 1;
  text-align: left;
}

.role-label {
  font-size: 30rpx;
  color: #262626;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.role-desc {
  font-size: 24rpx;
  color: #8c8c8c;
  line-height: 1.5;
}

.profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  margin-bottom: 20rpx;
  border: 6rpx solid #e6f7ff;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.15);
}

.nick {
  font-size: 34rpx;
  color: #262626;
  font-weight: 600;
}

.actions {
  margin-top: 32rpx;
  width: 100%;
}

.login-btn {
  width: 100%;
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  color: #fff;
  padding: 28rpx 0;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 32rpx rgba(24, 144, 255, 0.35);
  transition: all 0.3s ease;
  border: none;
  letter-spacing: 2rpx;
}

.login-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 6rpx 16rpx rgba(24, 144, 255, 0.35);
}

.login-btn::after {
  border: none;
}

.logout-btn {
  width: 100%;
  background: #f5f5f5;
  color: #8c8c8c;
  padding: 24rpx 0;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  border: none;
}

.logout-btn:active {
  background: #e8e8e8;
}

.logout-btn::after {
  border: none;
}

.status {
  margin-top: 32rpx;
  color: #8c8c8c;
  font-size: 26rpx;
  padding: 16rpx 24rpx;
  background: #f0f5ff;
  border-radius: 16rpx;
  border-left: 6rpx solid #1890ff;
}

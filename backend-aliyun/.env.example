# 服务器配置
PORT=3000
NODE_ENV=production

# 数据库配置 - 选择其中一种

# 方案A: RDS MySQL (推荐生产环境)
# DB_TYPE=mysql
# MYSQL_HOST=rm-xxxxx.mysql.rds.aliyuncs.com
# MYSQL_PORT=3306
# MYSQL_USER=catplan
# MYSQL_PASSWORD=your-mysql-password
# MYSQL_DATABASE=catplan

# 方案B: RDS MongoDB
# DB_TYPE=mongodb
# MONGODB_URI=mongodb://username:password@dds-xxxxx.mongodb.rds.aliyuncs.com:3717,dds-xxxxx.mongodb.rds.aliyuncs.com:3717/catplan?replicaSet=mgset-xxxxx

# 方案C: 自建 MongoDB (默认)
DB_TYPE=mongodb
MONGODB_URI=mongodb://localhost:27017/catplan

# 方案D: 自建 MySQL
# DB_TYPE=mysql
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your-password
# MYSQL_DATABASE=catplan

# JWT 密钥（请更换为复杂的随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 微信小程序配置
WECHAT_APPID=wx557d4f3490a318fe
WECHAT_APPSECRET=your-wechat-appsecret

# 阿里云 OSS 配置
ALIYUN_OSS_REGION=oss-cn-hangzhou
ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_OSS_BUCKET=catplan
ALIYUN_OSS_DOMAIN=https://catplan.oss-cn-hangzhou.aliyuncs.com

# 日志配置
LOG_LEVEL=info
